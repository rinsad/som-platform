# SOM Platform backend environment example
# Copy to .env and adjust for your local machine.

# Server
PORT=5000

# PostgreSQL connection used by backend/src/database/db.js
# Example local database:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/som_platform

# Required for login/session JWT signing.
# Replace this with a long random value before using outside local development.
JWT_SECRET=change-me-local-development-secret

# Optional: enables knowledge-base embedding/search features in kbController.js.
# Leave blank if you are not using OpenAI-backed knowledge search locally.
OPENAI_API_KEY=

# Optional: used by npm run seed:capex-video-users.
CAPEX_VIDEO_USER_PASSWORD=Video@SOM2026!
